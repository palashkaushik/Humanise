---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <header class="text-center mb-10">
      <h1 class="text-4xl font-bold mb-2">Get Your API Key</h1>
      <p class="text-zinc-400 text-lg">Add AI humanization to any website with one line of code</p>
    </header>

    <div class="space-y-6">
      <!-- Step 1: Get Key -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-3 text-zinc-200">1. Get your free API key</h2>
        <div class="flex gap-3">
          <input id="keyName" type="text" placeholder="Your website name (optional)" 
            class="flex-1 bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-200 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600" />
          <button id="getKeyBtn" class="bg-emerald-600 hover:bg-emerald-500 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">
            Generate Key
          </button>
        </div>
        <div id="keyResult" class="hidden mt-4">
          <p class="text-emerald-400 text-sm mb-2">Your API key (save it now, won't be shown again):</p>
          <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3 flex items-center gap-3">
            <code id="keyValue" class="text-emerald-300 text-sm font-mono flex-1 break-all"></code>
            <button id="copyKey" class="text-zinc-500 hover:text-zinc-300 text-sm whitespace-nowrap">Copy</button>
          </div>
        </div>
      </div>

      <!-- Step 2: Add Script -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-3 text-zinc-200">2. Add this to your website</h2>
        <p class="text-zinc-500 text-sm mb-3">Paste this single line before &lt;/body&gt; on any page:</p>
        <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3">
          <code id="embedCode" class="text-emerald-300 text-xs font-mono break-all">&lt;script src="https://humanise.onrender.com/widget.js?key=YOUR_KEY"&gt;&lt;/script&gt;</code>
        </div>
        <p class="text-zinc-600 text-xs mt-2">Replace <code class="text-zinc-400">YOUR_KEY</code> with your actual API key</p>
      </div>

      <!-- Step 3: What You Get -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-3 text-zinc-200">3. What you get</h2>
        <ul class="space-y-2 text-sm text-zinc-400">
          <li class="flex items-start gap-2">
            <span class="text-emerald-400 mt-0.5">&#10003;</span>
            <span>Floating "Humanise" button on your site</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-400 mt-0.5">&#10003;</span>
            <span>Users paste AI text, click Humanize, get human-sounding output</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-400 mt-0.5">&#10003;</span>
            <span>4 rewrite strengths: Light, Medium, Aggressive, Ninja</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-400 mt-0.5">&#10003;</span>
            <span>Free tier: 50 requests/day, 5 requests/minute</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-400 mt-0.5">&#10003;</span>
            <span>Powered by Gemini & Groq (zero cost to you)</span>
          </li>
        </ul>
      </div>

      <!-- Check Usage -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-3 text-zinc-200">Check your usage</h2>
        <div class="flex gap-3">
          <input id="usageKey" type="text" placeholder="Paste your API key" 
            class="flex-1 bg-zinc-950 border border-zinc-800 rounded-lg px-4 py-2 text-sm text-zinc-200 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 font-mono" />
          <button id="checkUsageBtn" class="border border-zinc-700 hover:border-zinc-500 text-zinc-300 px-4 py-2 rounded-lg text-sm transition-colors whitespace-nowrap">
            Check
          </button>
        </div>
        <div id="usageResult" class="hidden mt-4 text-sm text-zinc-400"></div>
      </div>

      <!-- API Docs -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-3 text-zinc-200">API Reference</h2>
        <div class="space-y-3 text-sm">
          <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3">
            <p class="text-zinc-300 font-mono text-xs mb-1">POST /api/humanize</p>
            <pre class="text-zinc-500 text-xs">{"{text, strength, feedback}"}</pre>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3">
            <p class="text-zinc-300 font-mono text-xs mb-1">POST /api/detect</p>
            <pre class="text-zinc-500 text-xs">{"{text}"}</pre>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-3">
            <p class="text-zinc-300 font-mono text-xs mb-1">POST /api/rules</p>
            <pre class="text-zinc-500 text-xs">{"{text}"}</pre>
          </div>
          <p class="text-zinc-600 text-xs">All endpoints require: <code class="text-zinc-400">Authorization: Bearer YOUR_KEY</code></p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
const API = 'https://humanise.onrender.com';

document.getElementById('getKeyBtn').addEventListener('click', async () => {
  const name = document.getElementById('keyName').value.trim();
  const btn = document.getElementById('getKeyBtn');
  btn.textContent = 'Generating...';
  btn.disabled = true;
  try {
    const r = await fetch(`${API}/api/keys/generate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name }),
    });
    const d = await r.json();
    document.getElementById('keyValue').textContent = d.key;
    document.getElementById('embedCode').textContent = `<script src="https://humanise.onrender.com/widget.js?key=${d.key}"><\/script>`;
    document.getElementById('keyResult').classList.remove('hidden');
  } catch (e) {
    alert('Error: ' + e.message);
  }
  btn.textContent = 'Generate Key';
  btn.disabled = false;
});

document.getElementById('copyKey').addEventListener('click', () => {
  const key = document.getElementById('keyValue').textContent;
  navigator.clipboard.writeText(key);
  document.getElementById('copyKey').textContent = 'Copied!';
  setTimeout(() => document.getElementById('copyKey').textContent = 'Copy', 2000);
});

document.getElementById('checkUsageBtn').addEventListener('click', async () => {
  const key = document.getElementById('usageKey').value.trim();
  if (!key) return;
  const result = document.getElementById('usageResult');
  result.classList.remove('hidden');
  result.innerHTML = '<p class="text-zinc-500">Loading...</p>';
  try {
    const r = await fetch(`${API}/api/keys/usage`, {
      headers: { 'Authorization': `Bearer ${key}` },
    });
    const d = await r.json();
    if (r.ok) {
      const remaining = d.daily_limit ? d.daily_limit - d.daily_requests : 'unlimited';
      result.innerHTML = `
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-zinc-950 border border-zinc-800 rounded p-3">
            <div class="text-zinc-300 font-semibold">${d.tier}</div>
            <div class="text-zinc-600 text-xs">Tier</div>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded p-3">
            <div class="text-zinc-300 font-semibold">${d.total_requests}</div>
            <div class="text-zinc-600 text-xs">Total requests</div>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded p-3">
            <div class="text-zinc-300 font-semibold">${d.daily_requests}/${d.daily_limit || '∞'}</div>
            <div class="text-zinc-600 text-xs">Today</div>
          </div>
          <div class="bg-zinc-950 border border-zinc-800 rounded p-3">
            <div class="text-zinc-300 font-semibold">${remaining}</div>
            <div class="text-zinc-600 text-xs">Remaining today</div>
          </div>
        </div>`;
    } else {
      result.innerHTML = `<p class="text-red-400">${d.detail?.message || 'Invalid key'}</p>`;
    }
  } catch (e) {
    result.innerHTML = `<p class="text-red-400">Error: ${e.message}</p>`;
  }
});
</script>
